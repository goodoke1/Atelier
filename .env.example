# ───────────────────────────────────────────────────────────────
# Atelier configuration. Copy to `.env`
# ───────────────────────────────────────────────────────────────

# Which multimodal model classifies images: claude | openai | ollama
MODEL_PROVIDER=claude

# Anthropic Claude (default, recommended). Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (alternative). Used only when MODEL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local, free, no key). Used only when MODEL_PROVIDER=ollama.
# Requires Ollama running on the host with a vision model, e.g. `ollama pull llava`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava

# Set to 1 to run fully offline with a deterministic fake classifier
# (great for a no-key demo of the UI + search + filters). Overrides the provider.
FASHION_AI_STUB=
